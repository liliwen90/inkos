# HintOS Environment Configuration
# Copy to .env and fill in your values

# LLM Provider (openai, anthropic, custom)
HINTOS_LLM_PROVIDER=openai

# API Base URL (OpenAI-compatible endpoint)
HINTOS_LLM_BASE_URL=https://api.openai.com/v1

# API Key
HINTOS_LLM_API_KEY=sk-your-key-here

# Model name
HINTOS_LLM_MODEL=gpt-4o

# Notifications (optional)
HINTOS_TELEGRAM_BOT_TOKEN=
HINTOS_TELEGRAM_CHAT_ID=
HINTOS_FEISHU_WEBHOOK_URL=
HINTOS_WECOM_WEBHOOK_URL=
